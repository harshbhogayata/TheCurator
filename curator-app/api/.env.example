DJANGO_SECRET_KEY=change-this-before-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
API_PUBLIC_BASE_URL=http://127.0.0.1:8000

DATABASE_URL=postgresql://curator:curator@127.0.0.1:5432/curator

CORS_ALLOWED_ORIGINS=http://127.0.0.1:8081,http://localhost:8081,http://127.0.0.1:19000,http://localhost:19000,http://127.0.0.1:19006,http://localhost:19006
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8081,http://localhost:8081,http://127.0.0.1:19006,http://localhost:19006
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_HTTPONLY=false
CSRF_COOKIE_SAMESITE=Lax
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=false
SECURE_HSTS_PRELOAD=false
SECURE_SSL_REDIRECT=false
TRUST_PROXY=false

FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_PATH=
FIREBASE_CREDENTIALS_JSON=
FIREBASE_CLOCK_SKEW_SECONDS=60
# Local DEBUG only. Keep 0 unless the workstation clock cannot be synchronized.
FIREBASE_LOCAL_CLOCK_OFFSET_SECONDS=0

CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1

REVENUECAT_WEBHOOK_SECRET=
REVENUECAT_PRODUCT_TIER_MAP={}

# Stripe web checkout. Map tiers to Stripe Price IDs.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_TIER_PRICE_MAP={"basic": "", "premium": "", "lifetime": ""}
WEB_BASE_URL=http://localhost:3000

# Web Push (VAPID). Generate with `npx web-push generate-vapid-keys`.
WEBPUSH_VAPID_PUBLIC_KEY=
WEBPUSH_VAPID_PRIVATE_KEY=
WEBPUSH_VAPID_CLAIMS_EMAIL=
