DJANGO_SECRET_KEY=change-this-before-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
API_PUBLIC_BASE_URL=http://127.0.0.1:8000

DATABASE_URL=postgresql://curator:curator@127.0.0.1:5432/curator

CORS_ALLOWED_ORIGINS=http://127.0.0.1:8081,http://localhost:8081,http://127.0.0.1:19000,http://localhost:19000,http://127.0.0.1:19006,http://localhost:19006
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8081,http://localhost:8081,http://127.0.0.1:19006,http://localhost:19006
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_HTTPONLY=false
CSRF_COOKIE_SAMESITE=Lax
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=false
SECURE_HSTS_PRELOAD=false
SECURE_SSL_REDIRECT=false
TRUST_PROXY=false

FIREBASE_PROJECT_ID=
FIREBASE_WEB_API_KEY=
FIREBASE_WEB_AUTH_DOMAIN=
FIREBASE_WEB_APP_ID=
FIREBASE_CREDENTIALS_PATH=
FIREBASE_CREDENTIALS_JSON=
FIREBASE_CLOCK_SKEW_SECONDS=60
# Local DEBUG only. Keep 0 unless the workstation clock cannot be synchronized.
FIREBASE_LOCAL_CLOCK_OFFSET_SECONDS=0

CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1

REVENUECAT_WEBHOOK_SECRET=
REVENUECAT_API_KEY=
REVENUECAT_PRODUCT_TIER_MAP={}

# Stripe web checkout (optional if Razorpay is configured).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_TIER_PRICE_MAP={"basic": "", "premium": "", "lifetime": ""}

# Razorpay International — preferred web billing provider when keys are set.
WEB_BILLING_PROVIDER=auto
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_TIER_PLAN_MAP={}
# When Razorpay Subscriptions are enabled, create monthly plans in Dashboard
# (Subscriptions → Plans) and set IDs, e.g.:
# RAZORPAY_TIER_PLAN_MAP={"basic": "plan_xxx", "premium": "plan_yyy"}
# Leave empty {} to use one-time Standard Checkout orders for all tiers.
RAZORPAY_TIER_AMOUNT_MAP={"basic": 49900, "premium": 149900, "lifetime": 2499900}
RAZORPAY_LIFETIME_AMOUNT=2499900
RAZORPAY_CURRENCY=INR
RAZORPAY_SUBSCRIPTION_TOTAL_COUNT=120

WEB_BASE_URL=http://localhost:5173
# Production: https://thecuratorgroup.org
# Used as Firebase continue URL for password reset / verify emails (must be an authorized domain).
# Mobile app checkout page (defaults to {API_PUBLIC_BASE_URL}/m/donate)
MOBILE_DONATE_URL=
# Auth action pages in email links (default: {API_PUBLIC_BASE_URL}/m/reset-password and /m/verify-email)
MOBILE_RESET_PASSWORD_URL=
MOBILE_VERIFY_EMAIL_URL=
# Add API_PUBLIC_BASE_URL host to Firebase Console → Authentication → Settings → Authorized domains
DEFAULT_FROM_EMAIL=noreply@thecuratorgroup.org
# Easiest email setup: Resend (free tier). Skip Google SMTP/app passwords.
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@thecuratorgroup.org
LAUNCH_NOTIFY_FORWARD_ENABLED=true
LAUNCH_NOTIFY_FORWARD_EMAIL=harsh@thecuratorgroup.org
LAUNCH_NOTIFY_SEND_CONFIRMATION=true
# Production CORS — allow the launch site to POST /api/launch-notify:
# CORS_ALLOWED_ORIGINS=...,https://thecuratorgroup.org,https://www.thecuratorgroup.org

# Narration audio — production: kokoro (self-host) or speechmatics/openai. edge = dev/staging only.
# TTS_PROVIDER=kokoro|speechmatics|openai|edge|auto
TTS_PROVIDER=auto
KOKORO_TTS_URL=
# e.g. http://127.0.0.1:8880/v1 or full .../v1/audio/speech endpoint
KOKORO_TTS_MODEL=tts-1
KOKORO_TTS_VOICE=af_heart
# SPEECHMATICS_API_KEY=
EDGE_TTS_VOICE=en-US-JennyNeural
# Content pipeline (RSS → LLM → publish). Requires Celery or: python manage.py run_pipeline
PIPELINE_ENABLED=true
PIPELINE_AUTO_PUBLISH=false
PIPELINE_MIN_CLUSTER_SOURCES=5
PIPELINE_MAX_DRAFTS_PER_RUN=10
PIPELINE_GENERATE_AUDIO_ON_RUN=true
PIPELINE_AUDIO_LIMIT=25
PIPELINE_RESOLVE_IMAGES_ON_RUN=true
PIPELINE_IMAGE_LIMIT=25
PIPELINE_DAILY_BRIEF_ENABLED=true
PIPELINE_DAILY_BRIEF_AUTO_PUBLISH=true
PIPELINE_DAILY_BRIEF_MIN_ARTICLES=3
OPENAI_CHAT_MODEL=gpt-4o-mini
# Free stock photos for hero images (commercial use + attribution). https://www.pexels.com/api/
PEXELS_API_KEY=
# Optional premium abstract heroes — https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=
# India / regional news when RSS is weak — https://currentsapi.services/ (1k req/day free)
CURRENTS_API_KEY=
CURRENTS_DEFAULT_LANGUAGE=en
CURRENTS_DAILY_REQUEST_BUDGET=1000
# AUDIO_STORAGE_BACKEND=auto|local|s3
# For Railway without R2: set API_PUBLIC_BASE_URL and AUDIO_STORAGE_BACKEND=local
AUDIO_STORAGE_BACKEND=auto
AUDIO_LOCAL_URL_PREFIX=/api/mobile/v1/media/audio
# Optional OpenAI TTS (paid):
OPENAI_API_KEY=
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
# See docs/R2_AUDIO_SETUP.md for step-by-step Cloudflare R2 setup.
# Quick verify after configuring env:
#   python manage.py verify_audio_storage
#   python manage.py generate_content_audio --all-missing
# Cloudflare R2: create bucket, enable public URL or custom domain, then:
# AUDIO_STORAGE_BACKEND=s3
# AUDIO_S3_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
# AUDIO_S3_BUCKET=curator-audio
# AUDIO_PUBLIC_BASE_URL=https://audio.thecuratorgroup.org
AUDIO_S3_ENDPOINT_URL=
AUDIO_S3_BUCKET=
AUDIO_S3_ACCESS_KEY_ID=
AUDIO_S3_SECRET_ACCESS_KEY=
AUDIO_S3_REGION=auto
AUDIO_PUBLIC_BASE_URL=

# Web Push (VAPID). Generate with `npx web-push generate-vapid-keys`.
WEBPUSH_VAPID_PUBLIC_KEY=
WEBPUSH_VAPID_PRIVATE_KEY=
WEBPUSH_VAPID_CLAIMS_EMAIL=
