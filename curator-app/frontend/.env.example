# Django mobile API (same backend as Expo app)
VITE_API_URL=http://127.0.0.1:8000

# Firebase Auth (same project as mobile)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Public site URL used in canonical/OG tags (SSR)
VITE_SITE_URL=http://localhost:3000

# Web Push (VAPID public key; pair with API's WEBPUSH_VAPID_PRIVATE_KEY)
VITE_VAPID_PUBLIC_KEY=

# Image CDN template with {url} and {width} placeholders (optional), e.g.
# https://img.thecurator.app/cdn-cgi/image/width={width},format=auto/{url}
VITE_IMAGE_CDN_URL=

# Local dev helpers (same as mobile EXPO_PUBLIC_* flags)
VITE_DEV_BYPASS_AUTH=false
VITE_MOCK_BACKEND=false
VITE_MOCK_PREMIUM=false
VITE_MOBILE_LAYOUT=true
