{
  "cli": {
    "version": ">= 16.23.0",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "env": {
        "EXPO_PUBLIC_API_URL": "https://thecurator-production-1b47.up.railway.app",
        "EXPO_PUBLIC_SITE_URL": "https://thecuratorgroup.org",
        "EXPO_PUBLIC_EAS_PROJECT_ID": "584dd577-0bcb-4201-bb11-6f81bc75cc00",
        "EXPO_PUBLIC_BILLING_PROVIDER": "razorpay",
        "EXPO_PUBLIC_MOCK_BACKEND": "false",
        "EXPO_PUBLIC_MOCK_PREMIUM": "false",
        "EXPO_PUBLIC_DEV_BYPASS_AUTH": "false",
        "EXPO_PUBLIC_APP_BUNDLE_ID": "com.curator.mobile",
        "EXPO_PUBLIC_ANDROID_PACKAGE": "com.curator.mobile",
        "EXPO_PUBLIC_FIREBASE_IOS_BUNDLE_ID": "com.curator.mobile",
        "EXPO_PUBLIC_FIREBASE_ANDROID_PACKAGE": "com.curator.mobile"
      }
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "environment": "development",
      "env": {
        "APP_ENV": "development"
      }
    },
    "preview": {
      "extends": "base",
      "distribution": "internal",
      "channel": "preview",
      "environment": "preview",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "APP_ENV": "preview"
      }
    },
    "production": {
      "extends": "base",
      "autoIncrement": true,
      "channel": "production",
      "environment": "production",
      "env": {
        "APP_ENV": "production"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-play-key.json",
        "track": "internal"
      }
    }
  }
}
