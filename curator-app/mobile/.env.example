EXPO_PUBLIC_API_URL=http://127.0.0.1:8000
# Public site (privacy/terms links): https://thecuratorgroup.org
EXPO_PUBLIC_SITE_URL=https://thecuratorgroup.org
# On a physical device with Expo Go, localhost points at the phone — not your PC.
# Either keep 127.0.0.1 (the app auto-swaps to your Metro LAN IP in dev), or set:
# EXPO_PUBLIC_API_URL=http://192.168.x.x:8000
# For production-like testing without a local API:
# EXPO_PUBLIC_API_URL=https://thecurator-production-1b47.up.railway.app

# Local development mocks; production builds reject these when true.
# MOCK_BACKEND=true uses local mock briefs/articles (no Firebase/API auth). Set false for real backend content.
EXPO_PUBLIC_MOCK_BACKEND=false
EXPO_PUBLIC_MOCK_PREMIUM=false
EXPO_PUBLIC_DEV_BYPASS_AUTH=false
# Requires EXPO_PUBLIC_MOCK_BACKEND=true — see src/lib/dev-flags.ts (skipAuthGate).

# Production Firebase web API key (restricted to com.curator.mobile + EAS SHA-1 in Google Cloud).
EXPO_PUBLIC_FIREBASE_API_KEY=
# Expo Go only: create a second Google Cloud API key with NO application restrictions (dev machines).
# Restrict APIs to Identity Toolkit + Token Service. Used automatically in Expo Go when set.
EXPO_PUBLIC_FIREBASE_API_KEY_DEV=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_IOS_BUNDLE_ID=com.curator.mobile
EXPO_PUBLIC_FIREBASE_ANDROID_PACKAGE=com.curator.mobile

# Google Sign-In (Firebase Auth) — OAuth client IDs from Google Cloud Console
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

EXPO_PUBLIC_APP_BUNDLE_ID=com.curator.mobile
EXPO_PUBLIC_ANDROID_PACKAGE=com.curator.mobile
EXPO_PUBLIC_EAS_PROJECT_ID=
# EAS Build secrets: see eas.env.example (set via `npx eas env:create`, not in git).
# Razorpay web billing (preferred when RC keys are unset)
# EXPO_PUBLIC_BILLING_PROVIDER: auto | razorpay | revenuecat
EXPO_PUBLIC_BILLING_PROVIDER=razorpay
EXPO_PUBLIC_RAZORPAY_KEY_ID=
EXPO_PUBLIC_RC_IOS_KEY=
EXPO_PUBLIC_RC_ANDROID_KEY=
EXPO_PUBLIC_RC_BASIC_PRODUCT_ID=
EXPO_PUBLIC_RC_PREMIUM_PRODUCT_ID=
EXPO_PUBLIC_RC_LIFETIME_PRODUCT_ID=
EXPO_PUBLIC_RC_BASIC_ENTITLEMENT_ID=Basic
EXPO_PUBLIC_RC_PREMIUM_ENTITLEMENT_ID=Premium
EXPO_PUBLIC_RC_LIFETIME_ENTITLEMENT_ID=Lifetime

# Sentry (optional — app runs without it; set EXPO_PUBLIC_REQUIRE_SENTRY=true on production builds when ready)
EXPO_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
