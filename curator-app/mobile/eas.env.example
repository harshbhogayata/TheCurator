# EAS Build / Update environment variables
# Public client keys (Firebase, Razorpay test ID) are in eas.json base.env — required at compile time.
# Override or add secrets here via EAS dashboard or:
#   npx eas env:push preview --path .env
#
# Never commit server secrets (Sentry auth token, Play service account JSON).

# ─── Required for all EAS builds ───────────────────────────────────────────
EXPO_PUBLIC_API_URL=https://thecurator-production-1b47.up.railway.app
EXPO_PUBLIC_SITE_URL=https://thecuratorgroup.org
EXPO_PUBLIC_EAS_PROJECT_ID=584dd577-0bcb-4201-bb11-6f81bc75cc00
EXPO_PUBLIC_APP_BUNDLE_ID=com.curator.mobile
EXPO_PUBLIC_ANDROID_PACKAGE=com.curator.mobile
EXPO_PUBLIC_FIREBASE_ANDROID_PACKAGE=com.curator.mobile
EXPO_PUBLIC_FIREBASE_IOS_BUNDLE_ID=com.curator.mobile

# ─── Firebase (public client keys — still store in EAS, not git) ─────────────
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google Sign-In (public OAuth client IDs — also in eas.json base.env)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# ─── Billing ───────────────────────────────────────────────────────────────
EXPO_PUBLIC_BILLING_PROVIDER=razorpay
EXPO_PUBLIC_RAZORPAY_KEY_ID=

# RevenueCat (only if EXPO_PUBLIC_BILLING_PROVIDER=revenuecat)
EXPO_PUBLIC_RC_IOS_KEY=
EXPO_PUBLIC_RC_ANDROID_KEY=
EXPO_PUBLIC_RC_BASIC_PRODUCT_ID=
EXPO_PUBLIC_RC_PREMIUM_PRODUCT_ID=
EXPO_PUBLIC_RC_LIFETIME_PRODUCT_ID=

# ─── Optional ────────────────────────────────────────────────────────────────
EXPO_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
