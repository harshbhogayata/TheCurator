{
  "name": "mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "doctor": "expo-doctor",
    "test:e2e": "maestro test .maestro/smoke.yaml",
    "test:e2e:auth": "maestro test .maestro/flows/auth.yaml",
    "test:e2e:audio": "maestro test .maestro/flows/brief-audio-paywall.yaml .maestro/flows/article-audio-paywall.yaml",
    "eas:env:preview": "npx eas-cli env:push preview --path .env --force",
    "eas:update:preview": "npx eas-cli update --channel preview --environment preview --platform android",
    "eas:build:preview": "npx eas-cli build --profile preview --platform android",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@expo-google-fonts/manrope": "^0.4.2",
    "@expo-google-fonts/newsreader": "^0.4.1",
    "@expo/metro-runtime": "~6.1.2",
    "@gorhom/bottom-sheet": "^5.2.9",
    "@hookform/resolvers": "^3.9.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@sentry/react-native": "~7.2.0",
    "@shopify/flash-list": "^2.0.2",
    "@tanstack/query-async-storage-persister": "^5.100.9",
    "@tanstack/react-query": "^5.96.2",
    "@tanstack/react-query-persist-client": "^5.100.9",
    "axios": "^1.16.0",
    "axios-retry": "^4.5.0",
    "clsx": "^2.1.1",
    "expo": "~54.0.35",
    "expo-auth-session": "~7.0.11",
    "expo-av": "~16.0.8",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-speech": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "~29.0.18",
    "expo-web-browser": "~15.0.11",
    "firebase": "^12.11.0",
    "lucide-react-native": "^1.7.0",
    "nativewind": "^4.2.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.72.1",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-purchases": "^10.0.1",
    "react-native-razorpay": "^2.3.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "^0.5.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.17",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~54.0.10",
    "patch-package": "^8.0.1",
    "typescript": "~5.9.2"
  },
  "private": true,
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-razorpay"
        ],
        "listUnknownPackages": false
      }
    },
    "autolinking": {
      "android": {
        "exclude": [
          "react-native-razorpay"
        ]
      }
    }
  }
}
